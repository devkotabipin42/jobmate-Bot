{
  "name": "jobmate-automation-backend",
  "version": "1.0.0",
  "description": "Production-grade JobMate communication automation backend",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "test:aarati-employer": "node scripts/testAaratiEmployerCore.mjs",
    "test:hiring-parser": "node scripts/testHiringNeedParser.mjs",
    "check:aarati-employer": "node scripts/checkAaratiEmployer.mjs",
    "test:jobseeker-core": "node scripts/testJobseekerCore.mjs",
    "test:jobseeker-safety": "node scripts/testJobseekerSafety.mjs",
    "test:worker-profile-mapper": "node scripts/testWorkerProfileMapper.mjs",
    "test:jobseeker-application": "node scripts/testJobseekerApplicationFlow.mjs",
    "test:jobseeker-refinement": "node scripts/testJobseekerSearchRefinement.mjs",
    "test:followup-templates": "node scripts/testFollowupTemplates.mjs",
    "check:followups": "node --check src/services/followups/followupProcessor.service.js && node --check src/services/followups/followupRunner.service.js && node --check src/services/whatsapp/whatsappClient.service.js && node --check src/controllers/adminFollowup.controller.js && node --check src/routes/adminFollowup.routes.js && node --check scripts/testFollowupTemplates.mjs",
    "test:followup-processor:manual": "node scripts/testFollowupProcessorManual.mjs",
    "test:env-boolean": "node scripts/testEnvBooleanParsing.mjs",
    "check:whatsapp-media": "node --check src/services/whatsapp/whatsappClient.service.js && node --check src/services/uploads/documentUpload.service.js",
    "test:job-search-step": "node scripts/testJobSearchStepMessages.mjs",
    "test:safety-guards": "node scripts/testJobmateSafetyGuards.mjs",
    "test:conversation-repair": "node scripts/testJobmateConversationRepair.mjs",
    "test:knowledge-answer": "node scripts/testJobMateKnowledgeAnswer.mjs",
    "test:general-answer-gate": "node scripts/testJobMateGeneralAnswerGate.mjs"
  },
  "keywords": [],
  "author": "JobMate",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.15.2",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "mongoose": "^9.5.0",
    "morgan": "^1.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
